{
  "title": "Option Key App Launchers",
  "rules": [
    {
      "description": "Option+Z to Zed",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "z",
            "modifiers": {
              "mandatory": ["left_option"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "shell_command": "open -a 'Zed'"
            }
          ]
        }
      ]
    },
    {
      "description": "Option+B to Helium",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "b",
            "modifiers": {
              "mandatory": ["left_option"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "shell_command": "open -a 'Helium'"
            }
          ]
        }
      ]
    },
    {
